# Required LLM provider (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tracing provider (Langfuse)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com


# Required search provider (Tavily)
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
